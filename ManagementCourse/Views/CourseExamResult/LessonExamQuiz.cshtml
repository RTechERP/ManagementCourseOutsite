@section Styles {
<style>
    /* ===== BREADCRUMB ===== */
    .exam-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: #888;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }
    .exam-breadcrumb a { color: #888; text-decoration: none; transition: color .2s; }
    .exam-breadcrumb a:hover { color: #1677ff; }
    .exam-breadcrumb i { font-size: 14px; color: #bbb; }
    .exam-breadcrumb .exam-title {
        font-weight: 700;
        color: #1a1a1a;
        flex: 1;
    }

    /* ===== STAT CARDS ===== */
    .exam-stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
        margin-bottom: 20px;
    }
    @@media (max-width: 860px) { .exam-stats-row { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 480px) { .exam-stats-row { grid-template-columns: 1fr; } }

    .exam-stat-card {
        background: #fff;
        border: 1px solid #e8e8e8;
        border-radius: 10px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .exam-stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
    }
    .stat-icon-blue   { background: #e6f4ff; color: #1677ff; }
    .stat-icon-green  { background: #f6ffed; color: #52c41a; }
    .stat-icon-orange { background: #fff7e6; color: #fa8c16; }
    .stat-icon-purple { background: #f9f0ff; color: #722ed1; }
    .exam-stat-info { display: flex; flex-direction: column; }
    .exam-stat-label { font-size: 12px; color: #888; margin-bottom: 2px; }
    .exam-stat-value { font-size: 26px; font-weight: 800; color: #1a1a1a; line-height: 1; }

    /* ===== TABLE ===== */
    .exam-history-card {
        background: #fff;
        border: 1px solid #e8e8e8;
        border-radius: 10px;
        overflow: hidden;
    }
    .exam-history-card table thead th {
        background: #fafafa;
        font-size: 13px;
        font-weight: 700;
        color: #555;
        border-bottom: 1px solid #e8e8e8;
        padding: 11px 14px;
        white-space: nowrap;
    }
    .exam-history-card table tbody td {
        font-size: 13px;
        color: #333;
        padding: 11px 14px;
        vertical-align: middle;
        border-bottom: 1px solid #f5f5f5;
    }
    .exam-history-card table tbody tr:last-child td { border-bottom: none; }
    .exam-history-card table tbody tr:hover { background: #fafafa; }

    /* Badge trạng thái */
    .status-badge { font-weight: 600; font-size: 13px; white-space: nowrap; }
    .status-badge.passed { color: #52c41a; }
    .status-badge.failed { color: #ff4d4f; }

    /* Cột điểm */
    .score-cell { white-space: nowrap; }
    .score-current { font-weight: 700; color: #1a1a1a; }
    .score-goal { color: #aaa; font-size: 12px; }

    /* ===== MODAL FLEX STRUCTURE ===== */
    #modal_exam_test .modal-content {
        display: flex !important;
        flex-direction: column !important;
        height: 100% !important;
    }
    #modal_exam_test .modal-header {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        gap: 12px;
        background: #fff;
        border-bottom: 1px solid #dee2e6;
        padding: 10px 16px;
    }
    #modal_exam_test .modal-body {
        flex: 1 1 auto !important;
        overflow-y: auto !important;
    }

    /* Timer */
    .exam-timer-wrap {
        display: flex;
        align-items: center;
        gap: 4px;
        min-width: 90px;
    }

    /* Sticky footer */
    .exam-sticky-footer {
        background: #fff;
        border-top: 2px solid #dee2e6;
        padding: 10px 16px;
        flex-shrink: 0;
    }
    .sticky-nav-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 8px;
        flex-wrap: wrap;
    }
    .sticky-nav-label {
        font-size: 13px;
        font-weight: 600;
        color: #555;
        white-space: nowrap;
    }
    .sticky-question-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        flex: 1;
        min-width: 0;
    }
    .sticky-action-bar {
        display: flex;
        gap: 8px;
    }

    /* Detail mode: ẩn timer, nộp bài */
    #modal_exam_test.detail-mode .exam-timer-wrap,
    #modal_exam_test.detail-mode #btn_submit_exam {
        display: none !important;
    }

    /* Ảnh câu hỏi */
    .exam-question-image {
        max-width: 100%;
        max-height: 400px;
        object-fit: contain;
        border-radius: 6px;
        border: 1px solid #e8e8e8;
        cursor: zoom-in;
        display: block;
        margin-top: 8px;
        transition: opacity .15s;
    }
    .exam-question-image:hover { opacity: 0.85; }

</style>
}

<!-- ===== BREADCRUMB ===== -->
<nav class="exam-breadcrumb">
    <a asp-controller="Home" asp-action="Index"><i class="bx bx-home-alt"></i> Trang chủ</a>
    <i class="bx bx-chevron-right"></i>
    <a asp-controller="Lesson" asp-action="Index" asp-route-courseId="@ViewBag.CourseId">Khoá học @ViewBag.CourseName</a>
    <i class="bx bx-chevron-right"></i>
    <a asp-controller="CourseExamResult" asp-action="LessonExamQuiz" asp-route-lessonID="@ViewBag.LessonID" class="exam-title">Bài thi trắc nghiệm bài học @ViewBag.LessonName</a>
    <button class="btn btn-primary btn-sm ms-auto" onclick="return onStart(1, 0);">
        <i class='bx bx-plus-medical'></i> Làm bài thi
    </button>
</nav>

<!-- ===== 4 THẺ THỐNG KÊ ===== -->
<div class="exam-stats-row">
    <div class="exam-stat-card">
        <div class="exam-stat-icon stat-icon-blue"><i class="bx bx-bar-chart-alt-2"></i></div>
        <div class="exam-stat-info">
            <span class="exam-stat-label">Tổng lần thi</span>
            <span class="exam-stat-value" id="stat_total">—</span>
        </div>
    </div>
    <div class="exam-stat-card">
        <div class="exam-stat-icon stat-icon-green"><i class="bx bx-check-circle"></i></div>
        <div class="exam-stat-info">
            <span class="exam-stat-label">Đã đạt</span>
            <span class="exam-stat-value" id="stat_passed">—</span>
        </div>
    </div>
    <div class="exam-stat-card">
        <div class="exam-stat-icon stat-icon-orange"><i class="bx bx-poll"></i></div>
        <div class="exam-stat-info">
            <span class="exam-stat-label">Điểm TB</span>
            <span class="exam-stat-value" id="stat_avg">—</span>
        </div>
    </div>
    <div class="exam-stat-card">
        <div class="exam-stat-icon stat-icon-purple"><i class="bx bx-trophy"></i></div>
        <div class="exam-stat-info">
            <span class="exam-stat-label">Cao nhất</span>
            <span class="exam-stat-value" id="stat_best">—</span>
        </div>
    </div>
</div>

<!-- ===== BẢNG LỊCH SỬ THI ===== -->
<div class="exam-history-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Bài học</th>
                    <th>Đề thi</th>
                    <th>Kết quả</th>
                    <th>Thời gian hoàn thành</th>
                    <th>Điểm / Cần đạt</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="tbody_exam_result">
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">
                        <i class="bx bx-loader-alt bx-spin me-1"></i> Đang tải dữ liệu...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="modal_exam_test" tabindex="-1" aria-labelledby="titlePDF" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content" style="background-color: #eceef1;">

            <!-- Header: title + nộp bài + đóng -->
            <div class="modal-header">
                <div class="exam-timer-wrap" style="display: none;">
                    <h5 class="m-0 text-danger">
                        <i class="bx bx-alarm" style="font-size: 26px; vertical-align: middle;"></i>
                        <span class="fw-bold" id="test_time"></span>
                    </h5>
                </div>
                <h5 class="modal-title fs-5 text-uppercase text-center flex-grow-1 mx-2" id="titlePDF">Bài thi trắc nghiệm bài học</h5>
                <div class="d-flex align-items-center gap-2">
                    <button id="btn_submit_exam" class="btn btn-success btn-sm fw-bold" onclick="return onSubmit();" style="background-color: #198754 !important; border-color: #198754 !important;">Nộp bài</button>
                    <button type="button" class="btn-close" onclick="return onClose();"></button>
                </div>
            </div>

            <!-- Body: nội dung câu hỏi + đáp án + ảnh -->
            <div class="modal-body px-2 py-2">
                <div class="card">
                    <div class="card-body p-3">
                        <div class="row m-0 container-content">
                            <div class="col-sm-12" id="container_question_content">
                                <h5 class="fw-bold m-0 p-0 pb-1">Câu <span id="current_question">1</span>/<span id="total_question_exam">40</span>:</h5>
                                <div class="col-12 pe-0" id="exam_question_content"></div>
                                <div class="pb-3 col-12">
                                    <h6 class="text-muted p-0 mb-2">Câu trả lời:</h6>
                                    <div class="card-body p-0" id="exam_content_answer"></div>
                                </div>
                            </div>
                            <div class="col-sm-6 col-12 p-0" id="image_question_container"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sticky footer: danh sách câu hỏi + action buttons -->
            <div class="exam-sticky-footer">
                <div class="sticky-action-bar mb-2">
                    <button class="btn btn-primary btn-sm" title="Previous" onclick="return onPrevios();">
                        <i class='bx bxs-chevron-left'></i>
                    </button>
                    <button class="btn btn-primary btn-sm" title="Next" onclick="return onNext();">
                        <i class='bx bxs-chevron-right'></i>
                    </button>
                </div>
                <div class="sticky-nav-row">
                    <div id="exam_question_navigation" class="sticky-question-nav"></div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        var lessonID = @ViewBag.LessonID;
        var courseExamId = @ViewBag.CourseExamID;
        var testTime = @ViewBag.TestTime;
    </script>
}

<script src="~/js/lesson_exam_quiz.js" asp-append-version="true"></script>
