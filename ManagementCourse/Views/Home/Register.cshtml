@{
    Layout = null;
}

<!DOCTYPE html>

<html lang="en"
      class="light-style customizer-hide"
      dir="ltr"
      data-theme="theme-default"
      data-assets-path="../assets/"
      data-template="vertical-menu-template-free">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

    <title>Đăng ký RTCCourse</title>

    <meta name="description" content="" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="~/assets/img/favicon/icon-logo-RTC-2023.ico" />

    <!-- Fonts -->
    <link href="~/assets/css/fontcss2.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/assets/vendor/fonts/boxicons.css" />

    <!-- Core CSS -->
    <link rel="stylesheet" href="~/assets/vendor/css/core.css" class="template-customizer-core-css" />
    <link rel="stylesheet" href="~/assets/vendor/css/theme-default.css" class="template-customizer-theme-css" />
    <link rel="stylesheet" href="~/assets/css/demo.css" />

    <!-- Vendors CSS -->
    <link rel="stylesheet" href="~/assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.css" />

    <!-- Page CSS -->
    <link rel="stylesheet" href="~/assets/vendor/css/pages/page-auth.css" />

    <style>
        .input-group .input-group-text {
            background-color: transparent;
            border-right: 0;
            color: #a1acb8;
            transition: color 0.15s ease, border-color 0.15s ease;
        }
        .input-group .form-control {
            border-left: 0;
        }
        .input-group .form-control:focus {
            box-shadow: none;
        }
        .input-group:focus-within .input-group-text,
        .input-group:focus-within .form-control,
        .input-group:focus-within .toggle-password {
            border-color: #86b7fe;
        }
        .input-group:focus-within .input-group-text {
            color: #696cff;
        }
        .toggle-password {
            border-left: 0;
            border-color: #ced4da;
            background: transparent;
            color: #a1acb8;
            transition: color 0.15s ease;
        }
        .toggle-password:hover,
        .toggle-password:focus,
        .toggle-password:active {
            background: transparent !important;
            color: #696cff !important;
            border-color: #ced4da !important;
            box-shadow: none !important;
        }
    </style>

</head>

<body>
    <!-- Content -->
    <div class="container-xxl">
        <div class="authentication-wrapper authentication-basic container-p-y">
            <div class="authentication-inner">
                <!-- Register -->
                <div class="card">
                    <div class="card-body">
                        <!-- Logo -->
                        <div class="app-brand justify-content-center mb-0">
                            <img src="~/assets/img/logo-RTC-2023-1200-banchuan.png" alt="" width="40%">
                        </div>
                        <div class="app-brand justify-content-center">
                            <span class="app-brand-text demo text-body fw-bolder text-uppercase mt-2">ĐĂNG KÝ</span>
                        </div>
                        <!-- /Logo -->

                        <p class="text-danger" id="errorMessage">@ViewBag.Error</p>
                        <p class="text-success" id="successMessage">@ViewBag.Success</p>

                        <form asp-controller="Home"
                              asp-action="Register"
                              method="post" class="needs-validation" id="registerForm">
                            <div class="row align-items-start">
                                <!-- Cột trái -->
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="fullName" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bx bx-user"></i></span>
                                            <input type="text"
                                                   class="form-control"
                                                   id="fullName"
                                                   name="fullName"
                                                   value="@ViewData["FullName"]"
                                                   placeholder="Nhập họ và tên"
                                                   required />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="birthDate" class="form-label">Ngày sinh <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bx bx-calendar"></i></span>
                                            <input type="date"
                                                   class="form-control"
                                                   id="birthDate"
                                                   name="birthDate"
                                                   value="@ViewData["BirthDate"]"
                                                   required />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="PhoneNumber" class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bx bx-phone"></i></span>
                                            <input type="tel"
                                                   class="form-control"
                                                   id="PhoneNumber"
                                                   name="PhoneNumber"
                                                   value="@ViewData["PhoneNumber"]"
                                                   placeholder="Nhập số điện thoại"
                                                   pattern="0[0-9]{9}"
                                                   title="Số điện thoại phải gồm 10 chữ số và bắt đầu bằng 0"
                                                   required />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="Organization" class="form-label">Đơn vị/ tổ chức <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bx bx-buildings"></i></span>
                                            <input type="text"
                                                   class="form-control"
                                                   id="Organization"
                                                   name="Organization"
                                                   value="@ViewData["Organization"]"
                                                   placeholder="Nhập đơn vị/ tổ chức"
                                                   required />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="password" class="form-label">Mật khẩu <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bx bx-lock"></i></span>
                                            <input type="password"
                                                   class="form-control"
                                                   id="password"
                                                   name="password"
                                                   placeholder="Nhập mật khẩu (ít nhất 6 ký tự)"
                                                   required
                                                   minlength="6" />
                                            <button class="btn toggle-password" type="button" tabindex="-1">
                                                <i class="bx bx-hide"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <!-- Cột phải -->
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="email" class="form-label">Email <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bx bx-envelope"></i></span>
                                            <input type="email"
                                                   class="form-control"
                                                   id="email"
                                                   name="email"
                                                   value="@ViewData["Email"]"
                                                   placeholder="Nhập email"
                                                   required />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Giới tính <span class="text-danger">*</span></label>
                                        <div class="d-flex gap-3" style="padding-bottom: 14.2px;">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="gender" id="genderMale" value="1" @(ViewData["Gender"]?.ToString() == "1" ? "checked" : "") required>
                                                <label class="form-check-label" for="genderMale">Nam</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="gender" id="genderFemale" value="0" @(ViewData["Gender"]?.ToString() == "0" ? "checked" : "")>
                                                <label class="form-check-label" for="genderFemale">Nữ</label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label for="Address" class="form-label">Địa chỉ <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bx bx-map"></i></span>
                                            <input type="text"
                                                   class="form-control"
                                                   id="Address"
                                                   name="Address"
                                                   value="@ViewData["Address"]"
                                                   placeholder="Nhập địa chỉ"
                                                   required />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="Position" class="form-label">Chức vụ <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bx bx-briefcase"></i></span>
                                            <input type="text"
                                                   class="form-control"
                                                   id="Position"
                                                   name="Position"
                                                   value="@ViewData["Position"]"
                                                   placeholder="Nhập chức vụ"
                                                   required />
                                        </div>
                                    </div>

                                    
                                    <div class="mb-3">
                                        <label for="confirmPassword" class="form-label">Nhập lại mật khẩu <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bx bx-lock"></i></span>
                                            <input type="password"
                                                   class="form-control"
                                                   id="confirmPassword"
                                                   name="confirmPassword"
                                                   placeholder="Nhập lại mật khẩu"
                                                   required />
                                            <button class="btn toggle-password" type="button" tabindex="-1">
                                                <i class="bx bx-hide"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Nguồn giới thiệu - Full width -->
                            <div class="mb-3">
                                <label class="form-label">
                                    Nguồn giới thiệu <span class="text-danger">*</span>
                                </label>

                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="radio"
                                           id="sourceFacebook"
                                           name="ReferralSource"
                                           value="Mạng xã hội(Facebook, Tiktok, Youtube, LinkedIn...)"
                                           @(ViewData["ReferralSource"]?.ToString() == "Mạng xã hội(Facebook, Tiktok, Youtube, LinkedIn...)" ? "checked" : "")>
                                    <label class="form-check-label" for="sourceFacebook">
                                        Mạng xã hội(Facebook, Tiktok, Youtube, LinkedIn...)
                                    </label>
                                </div>

                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="radio"
                                           id="sourceGoogle"
                                           name="ReferralSource"
                                           value="Google Search, AI Chat (ChatGPT, Gemini, Claude...)"
                                           @(ViewData["ReferralSource"]?.ToString() == "Google Search, AI Chat (ChatGPT, Gemini, Claude...)" ? "checked" : "")>
                                    <label class="form-check-label" for="sourceGoogle">
                                        Google Search, AI Chat (ChatGPT, Gemini, Claude...)
                                    </label>
                                </div>

                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="radio"
                                           id="sourceFriend"
                                           name="ReferralSource"
                                           value="Bạn bè / Người quen giới thiệu"
                                           @(ViewData["ReferralSource"]?.ToString() == "Bạn bè / Người quen giới thiệu" ? "checked" : "")>
                                    <label class="form-check-label" for="sourceFriend">
                                        Bạn bè / Người quen giới thiệu
                                    </label>
                                </div>

                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="radio"
                                           id="sourceWebsite"
                                           name="ReferralSource"
                                           value="Website chính thức"
                                           @(ViewData["ReferralSource"]?.ToString() == "Website chính thức" ? "checked" : "")>
                                    <label class="form-check-label" for="sourceWebsite">
                                        Website chính thức
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="radio"
                                           id="sourceTrienLam"
                                           name="ReferralSource"
                                           value="Sự kiện, Triển lãm, Ngày hội việc làm..."
                                           @(ViewData["ReferralSource"]?.ToString() == "Sự kiện, Triển lãm, Ngày hội việc làm..." ? "checked" : "")>
                                    <label class="form-check-label" for="sourceTrienLam">
                                        Sự kiện, Triển lãm, Ngày hội việc làm...
                                    </label>
                                </div>


                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="radio"
                                           name="ReferralSource"
                                           id="sourceOther"
                                           value="Khác"
                                           @(ViewData["ReferralSource"]?.ToString() == "Khác" || (!string.IsNullOrEmpty(ViewData["ReferralSource"]?.ToString()) && !new[]{"Mạng xã hội(Facebook, Tiktok, Youtube, LinkedIn...)","Google Search, AI Chat (ChatGPT, Gemini, Claude...)","Bạn bè / Người quen giới thiệu","Website chính thức","Sự kiện, Triển lãm, Ngày hội việc làm..."}.Contains(ViewData["ReferralSource"]?.ToString())) ? "checked" : "")>
                                    <label class="form-check-label" for="sourceOther">
                                        Khác
                                    </label>
                                </div>

                                <input type="text"
                                       class="form-control mt-2"
                                       id="otherSourceText"
                                       name="OtherReferralSource"
                                       placeholder="Vui lòng ghi rõ"
                                       value="@ViewData["OtherReferralSource"]"
                                       style="display:none;">
                            </div>

                            <!-- Chủ đề bạn quan tâm -->
                            <div class="mb-3">
                                <label class="form-label">
                                    Chủ đề bạn quan tâm <span class="text-danger">*</span>
                                    <small class="text-muted ms-1">(Có thể chọn nhiều)</small>
                                </label>
                                <div class="row g-2" id="interestCheckboxes">
                                    @{
                                        var savedInterests = (ViewData["InterestedCatalogTypeIds"]?.ToString() ?? "").Split(',').Where(x => !string.IsNullOrEmpty(x)).ToList();
                                    }
                                    @foreach (var item in (IEnumerable<ManagementCourse.Models.CourseCatalogType>)ViewData["CourseCatalogTypes"])
                                    {
                                        <div class="col-md-6">
                                            <div class="form-check">
                                                <input class="form-check-input interest-checkbox"
                                                       type="checkbox"
                                                       id="interest_@item.Id"
                                                       name="InterestedCatalogTypeIds"
                                                       value="@item.Id"
                                                       @(savedInterests.Contains(item.Id.ToString()) ? "checked" : "") />
                                                <label class="form-check-label" for="interest_@item.Id">
                                                    @item.CourseCatalogTypeName
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div id="interestError" class="text-danger mt-1" style="display:none; font-size:0.875em;">
                                    Vui lòng chọn ít nhất một chủ đề bạn quan tâm!
                                </div>
                            </div>

                            <script>
                                // Khởi tạo: hiện ô text Khác nếu đang được chọn (sau lỗi validate server)
                                (function () {
                                    const otherInput = document.getElementById('otherSourceText');
                                    const sourceOther = document.getElementById('sourceOther');
                                    if (sourceOther && sourceOther.checked) {
                                        otherInput.style.display = 'block';
                                    }
                                })();

                                // Gắn event 'change' cho TẤT CẢ radio trong nhóm ReferralSource
                                document.querySelectorAll('input[name="ReferralSource"]')
                                    .forEach(function (radio) {
                                        radio.addEventListener('change', function () {
                                            const otherInput = document.getElementById('otherSourceText');
                                            const isOther = document.getElementById('sourceOther').checked;

                                            if (isOther) {
                                                otherInput.style.display = 'block';
                                            } else {
                                                // Chọn lại option khác => ẩn và clear ô nhập
                                                otherInput.style.display = 'none';
                                                otherInput.value = '';
                                                // Reset value của sourceOther về mặc định
                                                document.getElementById('sourceOther').value = 'Khác';
                                            }
                                        });
                                    });

                                // Khi nhập vào ô text "Khác", cập nhật value của radio sourceOther
                                document.getElementById('otherSourceText')
                                    .addEventListener('input', function () {
                                        if (document.getElementById('sourceOther').checked) {
                                            document.getElementById('sourceOther').value = this.value || 'Khác';
                                        }
                                    });

                                // Toggle hiện/ẩn mật khẩu
                                document.querySelectorAll('.toggle-password').forEach(function (btn) {
                                    btn.addEventListener('click', function () {
                                        const input = this.closest('.input-group').querySelector('input[type="password"], input[type="text"]');
                                        const icon = this.querySelector('i');
                                        if (input.type === 'password') {
                                            input.type = 'text';
                                            icon.classList.replace('bx-hide', 'bx-show');
                                        } else {
                                            input.type = 'password';
                                            icon.classList.replace('bx-show', 'bx-hide');
                                        }
                                    });
                                });
                            </script>

                            <div class="mb-3">
                                <button class="btn btn-primary d-grid w-100" type="button" id="btnRegister" onclick="submitRegister()">Đăng ký</button>
                            </div>
                            <script>
                                function submitRegister() {
                                    const checked = document.querySelectorAll('.interest-checkbox:checked');
                                    const errorDiv = document.getElementById('interestError');
                                    if (checked.length === 0) {
                                        errorDiv.style.display = 'block';
                                        document.getElementById('interestCheckboxes').scrollIntoView({ behavior: 'smooth', block: 'center' });
                                        return;
                                    }
                                    errorDiv.style.display = 'none';
                                    document.getElementById('registerForm').submit();
                                }
                                // Ẩn lỗi khi người dùng bắt đầu chọn
                                document.querySelectorAll('.interest-checkbox').forEach(function (cb) {
                                    cb.addEventListener('change', function () {
                                        const anyChecked = document.querySelectorAll('.interest-checkbox:checked').length > 0;
                                        document.getElementById('interestError').style.display = anyChecked ? 'none' : 'block';
                                    });
                                });
                            </script>
                        </form>

                        <p class="text-center mt-3">
                            Đã có tài khoản? <a asp-controller="Home" asp-action="Login">Đăng nhập</a>
                        </p>
                    </div>
                </div>
                <!-- /Register -->
            </div>
        </div>
    </div>

</body>
</html>
