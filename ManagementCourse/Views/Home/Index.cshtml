@using Microsoft.AspNetCore.Http;
@model List<ManagementCourse.Models.DTO.CourseDTO>;
@using ManagementCourse.Models.Context;

@{
    Layout = "_LayoutF8";
    RTCCourseContext context = new RTCCourseContext();
    string fullName = Context.Session.GetString("fullname") ?? "Người dùng";
    string loginName = Context.Session.GetString("loginname") ?? "";
    int selectedCatalog = ViewBag.CoureCatalogID ?? 0;
    string defaultThumbnail = ViewBag.DefaultThumbnail;
    var listExams = ViewBag.ListExam as List<ManagementCourse.Models.CourseExam> ?? new List<ManagementCourse.Models.CourseExam>();
}

