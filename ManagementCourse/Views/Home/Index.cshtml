    <div class="custom-stats-bar">
        <div class="custom-stat-item">
            <div class="stat-icon-wrapper icon-bg-blue">
                <i class="bx bxs-graduation" style="font-size: 35px;"></i>
            </div>
            <div class="custom-stat-info">
                <div class="custom-stat-value val-blue">@totalCourses</div>
                <div class="custom-stat-label">Khóa học</div>
            </div>
        </div>
        <div class="custom-stat-item">
            <div class="stat-icon-wrapper icon-bg-green">
                <i class="bx bxs-book-open" style="font-size: 35px;"></i>
            </div>
            <div class="custom-stat-info">
                <div class="custom-stat-value val-green">@inProgressCourses</div>
                <div class="custom-stat-label">Đang học</div>
            </div>
        </div>
        <div class="custom-stat-item">
            <div class="stat-icon-wrapper icon-bg-orange">
                <i class="bx bx-line-chart" style="font-size: 35px;"></i>
            </div>
            <div class="custom-stat-info">
                <div class="custom-stat-value val-orange">@completedCourses</div>
                <div class="custom-stat-label" >Hoàn thành</div>
            </div>
        </div>
        <div class="custom-stat-item">
            <div class="stat-icon-wrapper icon-bg-purple">
                <i class="bx bxs-trophy" style="font-size: 35px;"></i>
            </div>
            <div class="custom-stat-info">
                <div class="custom-stat-value val-purple">@(Model?.Sum(c => c.NumberLesson) ?? 0)</div>
                <div class="custom-stat-label">Tổng bài học</div>
            </div>
        </div>
    </div>

    <!-- COURSE SECTION -->
    @{
        var interestedIds = ViewBag.InterestedCatalogTypeIds as List<int> ?? new List<int>();
        int courseCatalogID = ViewBag.CoureCatalogID ?? 0;
        bool isGroupedView = courseCatalogID == 0 && interestedIds.Count > 0;
        var displayModel = isGroupedView
        ? Model?.Where(c => interestedIds.Contains(c.CatalogType)).ToList()
        : Model;
        var remainingModel = isGroupedView
        ? Model?.Where(c => !interestedIds.Contains(c.CatalogType)).ToList()
        : new List<ManagementCourse.Models.DTO.CourseDTO>();
    }

    @if (displayModel == null || !displayModel.Any())
    {
        <div class="section-header">
            <h2 class="section-title"><span>Dành cho bạn</span></h2>
        </div>
        <div class="empty-state">
            <div><i class="bx bx-book-content"></i></div>
            <p>Chưa có khoá học nào. Vui lòng liên hệ quản trị viên.</p>
        </div>
    }
    else if (isGroupedView)
    {
        <!-- Hiển thị nhóm: Loại danh mục → Danh mục → Course cards -->
        <div class="section-box">
            <div class="section-header">
                <h2 class="section-title">
                    @if (!string.IsNullOrEmpty(ViewBag.TitleCourse as string))
                    {
                        @ViewBag.TitleCourse
                    }
                    else
                    {
                        <span>Dành cho bạn</span>
                    }
                </h2>
            </div>
            <div class="my-courses-section">
                @foreach (var typeGroup in displayModel.GroupBy(c => c.CatalogType).OrderBy(g => g.Key))
                {
                    <div class="catalog-type-block">


                        @foreach (var catalogGroup in typeGroup.GroupBy(c => c.CatalogID).OrderBy(g => g.Key))
                        {
                            <div class="catalog-sub-block">

                                <div class="catalog-type-header">


                                    <span style="color:#1677ff">Khoá học @(catalogGroup.First().NameCourseCatalog ?? $"Danh mục #{catalogGroup.Key}")</span>
                                </div>
                                <div class="course-grid-wrapper">
                                    <div class="course-grid">
                                        @{
                                            int idxG = 0;
                                        }
                                        @foreach (var item in catalogGroup)
                                        {
                                            string thumbClassG = $"thumb-{idxG % 8}";
                                            bool canAccessG = item.Status == 1;
                                            int progressPctG = item.NumberLesson > 0
                                            ? (int)Math.Round((double)item.TotalHistoryLession / item.NumberLesson * 100)
                                            : 0;

                                            if (canAccessG)
                                            {
                                                <a asp-controller="Lesson" asp-action="Index"
                                                   asp-route-courseId="@item.ID"
                                                   asp-route-catalogId="@item.CatalogID"
                                                   class="course-card"
                                                   title="@item.NameCourse">
                                                    <div class="course-thumbnail @(string.IsNullOrEmpty(item.ThumbnailUrl) ? thumbClassG : "thumb-img")"
                                                         @(string.IsNullOrEmpty(item.ThumbnailUrl) ? Html.Raw($"style=\"background-image:url('{defaultThumbnail}')\"") : Html.Raw($"style=\"background-image:url('{item.ThumbnailUrl}')\""))>
                                                    </div>
                                                    <div class="course-info">
                                                        <div class="course-name">@item.NameCourse</div>
                                                        <div class="course-instructor">
                                                            @if (!string.IsNullOrEmpty(item.Instructor))
                                                            {
                                                                <span><i class="bx bx-user"></i> @item.Instructor</span>
                                                            }
                                                            @if (item.Evaluate == 1)
                                                            {
                                                                <span class="badge-status status-pass">
                                                                    <i class="bx bx-check-circle"></i> Đạt
                                                                </span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge-status status-fail">
                                                                    <i class="bx bx-error-circle"></i> @item.EvaluateText
                                                                </span>
                                                            }
                                                        </div>
                                                        <div class="course-rating" style="display: flex; align-items: center; gap: 12px; font-size: 13px; color: #666; white-space: nowrap;">
                                                            <span style="display: flex; align-items: center; gap: 4px; font-weight: 600;" title="Đánh giá: @item.AverageRating.ToString("0.0") sao">
                                                                <span class="stars-container" style="position: relative; display: inline-block; font-size: 14px; color: #e0e0e0; letter-spacing: 2px;">
                                                                    <i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i>
                                                                    <span class="stars-fill" style="position: absolute; top: 0; left: 0; overflow: hidden; white-space: nowrap; color: #faad14; width: @((item.AverageRating * 20).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;">
                                                                        <i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i>
                                                                    </span>
                                                                </span>
                                                                <span style="color: #faad14;">@item.AverageRating.ToString("0.0")</span>
                                                                <span style="font-weight: 400; color: #888;">(@item.TotalRatingsText)</span>
                                                            </span>
                                                            <span style="display: flex; align-items: center; gap: 4px;" title="Lượt thích">
                                                                <i class="bx bxs-heart" style="color: #ff4d4f;"></i> @item.TotalLikesText
                                                            </span>
                                                            <span style="display: flex; align-items: center; gap: 4px;" title="Lượt tham gia">
                                                                <i class="bx bxs-group" style="color: #1890ff;"></i> @item.TotalParticipantsText
                                                            </span>
                                                        </div>
                                                        <div class="course-meta">
                                                            <span><i class="bx bx-book"></i> @item.TotalHistoryLession/@item.NumberLesson bài</span>
                                                            @if (item.LeadTime > 0)
                                                            {
                                                                <span><i class="bx bx-time"></i> @item.LeadTime ngày</span>
                                                            }
                                                        </div>
                                                        @{
                                                            var courseExamsG = listExams.Where(x => x.CourseId == item.ID).ToList();
                                                        }
                                                        @if (courseExamsG.Any())
                                                        {
                                                            <div class="course-exams-container">
                                                                @foreach (var exam in courseExamsG)
                                                                {
                                                                    if (exam.ExamType == 1)
                                                                    {
                                                                        <div class="exam-score-chip quiz-chip" title="Trắc nghiệm: @item.QuizPoints.ToString("0.##")/@item.GoalMultiChoice.ToString("0.##")">
                                                                            <i class="bx bx-list-check"></i>
                                                                            <span>TN: @item.QuizPoints.ToString("0.##")/@item.GoalMultiChoice.ToString("0.##")</span>
                                                                        </div>
                                                                    }
                                                                    else if (exam.ExamType == 2)
                                                                    {
                                                                        <div class="exam-score-chip practice-chip" title="Thực hành: @item.PracticePoints.ToString("0.##")/@item.GoalPractice.ToString("0.##")">
                                                                            <i class="bx bx-desktop"></i>
                                                                            <span>TH: @item.PracticePoints.ToString("0.##")/@item.GoalPractice.ToString("0.##")</span>
                                                                        </div>
                                                                    }
