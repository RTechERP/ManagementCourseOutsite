                                                                    <i class="bx bxs-heart" style="color: #ff4d4f;"></i> @item.TotalLikesText
                                                                </span>
                                                                <span style="display: flex; align-items: center; gap: 4px;" title="Lượt tham gia">
                                                                    <i class="bx bxs-group" style="color: #1890ff;"></i> @item.TotalParticipantsText
                                                                </span>
                                                            </div>
                                                            <div class="course-price free">Miễn phí</div>
                                                            <div class="course-meta">
                                                                <span><i class="bx bx-book"></i> @item.NumberLesson bài</span>
                                                                @if (item.LeadTime > 0)
                                                                {
                                                                    <span><i class="bx bx-time"></i> @item.LeadTime ngày</span>
                                                                }
                                                            </div>
                                                            <div style="font-size:12px; color:#ff4d4f; margin-top:8px; display:flex; align-items:center; gap:4px;">
                                                                <i class="bx bx-lock"></i> Chưa mở khoá
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                                idxRG++;
                                            }
                                        </div>
                                        <div class="show-more-container">
                                            <button class="show-more-btn">
                                                <i class="bx bx-chevron-down"></i>
                                                Xem thêm <span class="more-count"></span> khoá học
                                            </button>
                                        </div>
                                    </div><!-- /.course-grid-wrapper -->
                                </div>
                
                                <!-- /.catalog-sub-block -->
                            }
                        </div>
                    }
                </div><!-- /.my-courses-section -->
            </div>
    
            <!-- /.section-box -->
        }
    }
    else
    {
        <!-- Group list (khi đang filter catalog cụ thể) -->
        <div class="my-courses-section">
            @foreach (var typeGroup in displayModel.GroupBy(c => c.CatalogType).OrderBy(g => g.Key))
            {
                <div class="catalog-type-block">
                    @foreach (var catalogGroup in typeGroup.GroupBy(c => c.CatalogID).OrderBy(g => g.Key))
                    {
                        <div class="catalog-sub-block">
                            <div class="catalog-type-header">
                                <span style="color:#1677ff">Khoá học @(catalogGroup.First().NameCourseCatalog ?? $"Danh mục #{catalogGroup.Key}")</span>
                            </div>
                            <div class="course-grid-wrapper">
                                <div class="course-grid">
                                    @{
                                        int idx = 0;
                                    }
                                    @foreach (var item in catalogGroup)
                                    {
                                        string thumbClass = $"thumb-{idx % 8}";
                                        bool canAccess = item.Status == 1;
                                        int progressPct = item.NumberLesson > 0
                                        ? (int)Math.Round((double)item.TotalHistoryLession / item.NumberLesson * 100)
                                        : 0;

                                        if (canAccess)
                                        {
                                            <a asp-controller="Lesson" asp-action="Index"
                                               asp-route-courseId="@item.ID"
                                               asp-route-catalogId="@item.CatalogID"
                                               class="course-card"
                                               title="@item.NameCourse">
                                                <div class="course-thumbnail @(string.IsNullOrEmpty(item.ThumbnailUrl) ? thumbClass : "thumb-img")"
                                                     @(string.IsNullOrEmpty(item.ThumbnailUrl) ? Html.Raw($"style=\"background-image:url('{defaultThumbnail}')\"") : Html.Raw($"style=\"background-image:url('{item.ThumbnailUrl}')\""))>
                                                </div>
                                                <div class="course-info">
                                                    <div class="course-name">@item.NameCourse</div>
                                                    <div class="course-instructor">
                                                        @if (!string.IsNullOrEmpty(item.Instructor))
                                                        {
                                                            <span><i class="bx bx-user"></i> @item.Instructor</span>
                                                        }
                                                        @if (item.Evaluate == 1)
                                                        {
                                                            <span class="badge-status status-pass">
                                                                <i class="bx bx-check-circle"></i> Đạt
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge-status status-fail">
                                                                <i class="bx bx-error-circle"></i> @item.EvaluateText
                                                            </span>
                                                        }
                                                    </div>
                                                    <div class="course-rating" style="display: flex; align-items: center; gap: 12px; font-size: 13px; color: #666; white-space: nowrap;">
                                                        <span style="display: flex; align-items: center; gap: 4px; font-weight: 600;" title="Đánh giá: @item.AverageRating.ToString("0.0") sao">
                                                            <span class="stars-container" style="position: relative; display: inline-block; font-size: 14px; color: #e0e0e0; letter-spacing: 2px;">
                                                                <i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i>
                                                                <span class="stars-fill" style="position: absolute; top: 0; left: 0; overflow: hidden; white-space: nowrap; color: #faad14; width: @((item.AverageRating * 20).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;">
                                                                    <i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i>
                                                                </span>
                                                            </span>
                                                            <span style="color: #faad14;">@item.AverageRating.ToString("0.0")</span>
                                                            <span style="font-weight: 400; color: #888;">(@item.TotalRatingsText)</span>
                                                        </span>
                                                        <span style="display: flex; align-items: center; gap: 4px;" title="Lượt thích">
                                                            <i class="bx bxs-heart" style="color: #ff4d4f;"></i> @item.TotalLikesText
                                                        </span>
                                                        <span style="display: flex; align-items: center; gap: 4px;" title="Lượt tham gia">
                                                            <i class="bx bxs-group" style="color: #1890ff;"></i> @item.TotalParticipantsText
                                                        </span>
                                                    </div>
                                                    <div class="course-meta">
                                                        <span><i class="bx bx-book"></i> @item.TotalHistoryLession/@item.NumberLesson bài</span>
                                                        @if (item.LeadTime > 0)
                                                        {
                                                            <span><i class="bx bx-time"></i> @item.LeadTime ngày</span>
                                                        }
                                                    </div>
                                                    @if (item.TotalHistoryLession > 0)
                                                    {
                                                        <div class="course-progress">
                                                            <div class="progress-bar-wrap">
                                                                <div class="progress-bar-fill" style="width:@progressPct%"></div>
                                                            </div>
                                                            <div class="progress-label">
                                                                <span>Tiến độ</span>
                                                                <span>@progressPct%</span>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </a>
                                        }
                                        else
                                        {
                                            <div class="course-card locked" title="Cần hoàn thành bài học trước đó để mở khoá.">
                                                <div class="course-thumbnail @(string.IsNullOrEmpty(item.ThumbnailUrl) ? thumbClass : "thumb-img")"
                                                     @(string.IsNullOrEmpty(item.ThumbnailUrl) ? Html.Raw($"style=\"background-image:url('{defaultThumbnail}')\"") : Html.Raw($"style=\"background-image:url('{item.ThumbnailUrl}')\""))>

                                                    <div class="lock-overlay">
                                                        <i class="bx bx-lock-alt"></i>
                                                    </div>

                                                </div>
                                                <div class="course-info">
                                                    <div class="course-name">@item.NameCourse</div>
                                                    @if (!string.IsNullOrEmpty(item.Instructor))
                                                    {
                                                        <div class="course-instructor">
                                                            <span><i class="bx bx-user"></i> @item.Instructor</span>
                                                        </div>
                                                    }
                                                    <div class="course-rating" style="display: flex; align-items: center; gap: 12px; font-size: 13px; color: #666; white-space: nowrap;">
                                                        <span style="display: flex; align-items: center; gap: 4px; font-weight: 600;" title="Đánh giá: @item.AverageRating.ToString("0.0") sao">
                                                            <span class="stars-container" style="position: relative; display: inline-block; font-size: 14px; color: #e0e0e0; letter-spacing: 2px;">
                                                                <i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i>
                                                                <span class="stars-fill" style="position: absolute; top: 0; left: 0; overflow: hidden; white-space: nowrap; color: #faad14; width: @((item.AverageRating * 20).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%;">
                                                                    <i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i><i class="bx bxs-star"></i>
                                                                </span>
                                                            </span>
                                                            <span style="color: #faad14;">@item.AverageRating.ToString("0.0")</span>
                                                            <span style="font-weight: 400; color: #888;">(@item.TotalRatingsText)</span>
                                                        </span>
                                                        <span style="display: flex; align-items: center; gap: 4px;" title="Lượt thích">
                                                            <i class="bx bxs-heart" style="color: #ff4d4f;"></i> @item.TotalLikesText
                                                        </span>
                                                        <span style="display: flex; align-items: center; gap: 4px;" title="Lượt tham gia">
                                                            <i class="bx bxs-group" style="color: #1890ff;"></i> @item.TotalParticipantsText
                                                        </span>
                                                    </div>
                                                    <div class="course-price free">Miễn phí</div>
                                                    <div class="course-meta">
                                                        <span><i class="bx bx-book"></i> @item.NumberLesson bài</span>
                                                        @if (item.LeadTime > 0)
                                                        {
                                                            <span><i class="bx bx-time"></i> @item.LeadTime ngày</span>
                                                        }
                                                    </div>
                                                    <div style="font-size:12px; color:#ff4d4f; margin-top:8px; display:flex; align-items:center; gap:4px;">
                                                        <i class="bx bx-lock"></i> Chưa mở khoá
                                                    </div>
                                                </div>
                                            </div>
                                        }

                                        idx++;
                                    }
                                </div>
                                <div class="show-more-container">
                                    <button class="show-more-btn">
                                        <i class="bx bx-chevron-down"></i>
                                        Xem thêm <span class="more-count"></span> khoá học
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }


    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.course-grid-wrapper').forEach(function (wrapper) {
                var grid = wrapper.querySelector('.course-grid');
                var btnContainer = wrapper.querySelector('.show-more-container');
                var btn = wrapper.querySelector('.show-more-btn');
                var countSpan = wrapper.querySelector('.more-count');
                const countItem = 1;
                if (!grid || !btn) return;

                var cards = Array.from(grid.querySelectorAll('.course-card'));
                if (cards.length === 0) return;

                // Nhóm card theo hàng (cùng offsetTop = cùng hàng)
                var rows = [];
                cards.forEach(function (card) {
                    var top = card.offsetTop;
                    var row = rows.find(function (r) { return r.top === top; });
                    if (!row) { row = { top: top, cards: [] }; rows.push(row); }
                    row.cards.push(card);
                });

                if (rows.length <= countItem) return; // Không cần show-more

                // Ẩn từ hàng 2 trở đi
                var hiddenCards = rows.slice(countItem).reduce(function (acc, r) {
                    return acc.concat(r.cards);
                }, []);
                hiddenCards.forEach(function (c) { c.style.display = 'none'; });

                // Hiện button với số đếm
                if (countSpan) countSpan.textContent = hiddenCards.length;
                btnContainer.style.display = 'flex';

                var expanded = false;
                btn.addEventListener('click', function () {
                    if (!expanded) {
                        hiddenCards.forEach(function (c) { c.style.display = ''; });
                        btn.innerHTML = '<i class="bx bx-chevron-up"></i> Thu gọn';
                        expanded = true;
                    } else {
                        hiddenCards.forEach(function (c) { c.style.display = 'none'; });
                        btn.innerHTML = '<i class="bx bx-chevron-down"></i> Xem thêm '
                            + hiddenCards.length + ' khoá học';
                        expanded = false;
                    }
                });
            });
        });
    </script>
    <script>
        // ===== FRONTEND SEARCH =====
        (function () {
            var searchInput = document.getElementById('search-input');
            if (!searchInput) return;

            searchInput.addEventListener('input', function () {
                var keyword = this.value.trim().toLowerCase();

                var allCards = Array.from(document.querySelectorAll('.course-card'));

                if (keyword === '') {
                    // Xoá tìm kiếm: khôi phục hiển thị
                    allCards.forEach(function (card) { card.style.display = ''; });
                    document.querySelectorAll('.catalog-type-block, .catalog-sub-block').forEach(function (el) {
                        el.style.display = '';
                    });
                    document.querySelectorAll('.section-header').forEach(function (el) {
                        el.style.display = '';
                    });
                    document.querySelectorAll('.my-courses-section').forEach(function (el) {
                        el.style.display = '';
                    });
                    // Khôi phục section-box
                    document.querySelectorAll('.section-box').forEach(function (box) {
                        box.style.display = '';
                    });
                    // Khôi phục show-more: ẩn lại từ hàng 2+
                    document.querySelectorAll('.course-grid-wrapper').forEach(function (wrapper) {
                        var grid = wrapper.querySelector('.course-grid');
                        var btnContainer = wrapper.querySelector('.show-more-container');
                        var btn = wrapper.querySelector('.show-more-btn');
                        var countSpan = wrapper.querySelector('.more-count');
                        if (!grid || !btn) return;
                        var cards = Array.from(grid.querySelectorAll('.course-card'));
                        var rows = [];
                        cards.forEach(function (card) {
                            card.style.display = '';
                            var top = card.offsetTop;
                            var row = rows.find(function (r) { return r.top === top; });
                            if (!row) { row = { top: top, cards: [] }; rows.push(row); }
                            row.cards.push(card);
                        });
                        var countItem = 1;
                        if (rows.length > countItem) {
                            rows.slice(countItem).forEach(function (r) {
                                r.cards.forEach(function (c) { c.style.display = 'none'; });
                            });
                            var hidden = rows.slice(countItem).reduce(function (acc, r) { return acc.concat(r.cards); }, []);
                            if (countSpan) countSpan.textContent = hidden.length;
                            btn.innerHTML = '<i class="bx bx-chevron-down"></i> Xem thêm <span class="more-count">' + hidden.length + '</span> khoá học';
                            btnContainer.style.display = 'flex';
                        } else {
                            btnContainer.style.display = 'none';
                        }
                    });
                    return;
                }

                // Đang tìm kiếm: bỏ ẩn tất cả, ẩn show-more container
                document.querySelectorAll('.show-more-container').forEach(function (c) { c.style.display = 'none'; });

                // Filter card theo tên khoá học
                allCards.forEach(function (card) {
                    var name = '';
                    var nameEl = card.querySelector('.course-name');
                    if (nameEl) name = nameEl.textContent || '';
                    var match = name.toLowerCase().includes(keyword);
                    card.style.display = match ? '' : 'none';
                });

                // Ẩn catalog-sub-block không có kết quả
                document.querySelectorAll('.catalog-sub-block').forEach(function (block) {
                    var hasVisible = Array.from(block.querySelectorAll('.course-card')).some(function (c) {
                        return c.style.display !== 'none';
                    });
                    block.style.display = hasVisible ? '' : 'none';
                });

                // Ẩn catalog-type-block không có kết quả
                document.querySelectorAll('.catalog-type-block').forEach(function (block) {
                    var hasVisible = Array.from(block.querySelectorAll('.course-card')).some(function (c) {
                        return c.style.display !== 'none';
                    });
                    block.style.display = hasVisible ? '' : 'none';
                });

                // Ẩn section-header nếu my-courses-section không có kết quả
                document.querySelectorAll('.my-courses-section').forEach(function (section) {
                    var hasVisible = Array.from(section.querySelectorAll('.course-card')).some(function (c) {
                        return c.style.display !== 'none';
                    });
                    var header = section.previousElementSibling;
                    if (header && header.classList.contains('section-header')) {
                        header.style.display = hasVisible ? '' : 'none';
                    }
                    section.style.display = hasVisible ? '' : 'none';
                });

                // Ẩn section-box nếu không có course-card nào visible
                document.querySelectorAll('.section-box').forEach(function (box) {
                    var hasVisible = Array.from(box.querySelectorAll('.course-card')).some(function (c) {
                        return c.style.display !== 'none';
                    });
                    box.style.display = hasVisible ? '' : 'none';
                });
            });
        })();
    </script>
    <script>
        courseCatalogID = @ViewBag.CoureCatalogID;
        catalogType = @ViewBag.CatalogType;
    </script>
    <script src="~/js/home.js" asp-append-version="true"></script>
</body>
</html>