                                                                            <i class="bx bx-edit"></i>
                                                                            <span>BT: @item.ExcercisePoints.ToString("0.##")/@item.GoalExercise.ToString("0.##")</span>
                                                                        </div>
                                                                    }
                                                                }
                                                            </div>
                                                        }
                                                        @if (item.TotalHistoryLession > 0)
                                                        {
