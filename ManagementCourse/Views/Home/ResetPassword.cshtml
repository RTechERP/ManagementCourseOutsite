@{
    Layout = null;
    string tokenHash = ViewBag.TokenHash ?? "";
}

<!DOCTYPE html>
<html lang="vi"
      class="light-style customizer-hide"
      dir="ltr"
      data-theme="theme-default"
      data-assets-path="../assets/"
      data-template="vertical-menu-template-free">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />
    <title>Đặt lại mật khẩu – RTCCourse</title>
    <meta name="description" content="Đặt mật khẩu mới cho tài khoản RTCCourse" />
    <link rel="icon" type="image/x-icon" href="~/assets/img/favicon/icon-logo-RTC-2023.ico" />
    <link href="~/assets/css/fontcss2.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/assets/vendor/fonts/boxicons.css" />
    <link rel="stylesheet" href="~/assets/vendor/css/core.css" class="template-customizer-core-css" />
    <link rel="stylesheet" href="~/assets/vendor/css/theme-default.css" class="template-customizer-theme-css" />
    <link rel="stylesheet" href="~/assets/css/demo.css" />
    <link rel="stylesheet" href="~/assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.css" />
    <link rel="stylesheet" href="~/assets/vendor/css/pages/page-auth.css" />

    <style>
        .password-strength-bar {
            height: 4px;
            border-radius: 4px;
            background: #e0e0e0;
            margin-top: 6px;
            overflow: hidden;
        }
        .password-strength-bar-fill {
            height: 100%;
            width: 0;
            border-radius: 4px;
            transition: width 0.3s, background-color 0.3s;
        }
        .strength-very-weak { background-color: #ff7875; width: 15%; }
        .strength-weak      { background-color: #ffa940; width: 35%; }
        .strength-medium    { background-color: #faad14; width: 65%; }
        .strength-strong    { background-color: #52c41a; width: 100%; }
    </style>
</head>

<body>
    <div class="container-xxl">
        <div class="authentication-wrapper authentication-basic container-p-y">
            <div class="authentication-inner">
                <div class="card">
                    <div class="card-body">
                        <!-- Logo -->
                        <div class="app-brand justify-content-center mb-0">
                            <img src="~/assets/img/logo-RTC-2023-1200-banchuan.png" alt="" width="40%">
                        </div>
                        <div class="app-brand justify-content-center mb-3">
                            <span class="app-brand-text demo text-body fw-bolder text-uppercase mt-2">Đặt mật khẩu mới</span>
                        </div>

                        <p class="text-center text-muted mb-4" style="font-size: 14px;">
                            Mật khẩu mới phải có ít nhất 6 ký tự.
                        </p>

                        @if (!string.IsNullOrEmpty(ViewBag.Error as string))
                        {
                            <div class="alert alert-danger d-flex align-items-center mb-3" role="alert">
                                <i class="bx bx-error-circle me-2"></i>
                                <span>@ViewBag.Error</span>
                            </div>
                        }

                        <form method="post" action="/Home/ResetPassword" id="resetForm">
                            <input type="hidden" name="tokenHash" value="@tokenHash" />

                            <div class="mb-3">
                                <label for="newPassword" class="form-label">Mật khẩu mới</label>
                                <div class="input-group input-group-merge">
                                    <span class="input-group-text"><i class="bx bx-lock-alt"></i></span>
                                    <input type="password"
                                           class="form-control"
                                           id="newPassword"
                                           name="newPassword"
                                           placeholder="Nhập mật khẩu mới"
                                           minlength="6"
                                           required
                                           autofocus />
                                    <span class="input-group-text cursor-pointer" id="toggle-new-pwd">
                                        <i class="bx bx-hide" id="icon-new-pwd"></i>
                                    </span>
                                </div>
                                <div class="password-strength-bar mt-2">
                                    <div class="password-strength-bar-fill" id="strength-bar"></div>
                                </div>
                                <small id="strength-text" class="text-muted"></small>
                            </div>

                            <div class="mb-3">
                                <label for="confirmPassword" class="form-label">Xác nhận mật khẩu</label>
                                <div class="input-group input-group-merge">
                                    <span class="input-group-text"><i class="bx bx-lock-open-alt"></i></span>
                                    <input type="password"
                                           class="form-control"
                                           id="confirmPassword"
                                           name="confirmPassword"
                                           placeholder="Nhập lại mật khẩu mới"
                                           minlength="6"
                                           required />
                                    <span class="input-group-text cursor-pointer" id="toggle-confirm-pwd">
                                        <i class="bx bx-hide" id="icon-confirm-pwd"></i>
                                    </span>
                                </div>
                                <small id="match-hint" class="text-muted"></small>
                            </div>

                            <div class="mb-3">
                                <button class="btn btn-primary d-grid w-100" type="submit" id="btn-reset">
                                    Xác nhận đặt lại mật khẩu
                                </button>
                            </div>
                        </form>

                        <p class="text-center mt-3">
                            <a href="/Home/Login"><i class="bx bx-arrow-back me-1"></i>Quay lại đăng nhập</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Toggle show/hide password
        function togglePwd(toggleId, inputId, iconId) {
            document.getElementById(toggleId).addEventListener('click', function () {
                const input = document.getElementById(inputId);
                const icon = document.getElementById(iconId);
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.replace('bx-hide', 'bx-show');
                } else {
                    input.type = 'password';
                    icon.classList.replace('bx-show', 'bx-hide');
                }
            });
        }
        togglePwd('toggle-new-pwd', 'newPassword', 'icon-new-pwd');
        togglePwd('toggle-confirm-pwd', 'confirmPassword', 'icon-confirm-pwd');

        // Password strength
        const newPwdInput = document.getElementById('newPassword');
        const strengthBar = document.getElementById('strength-bar');
        const strengthText = document.getElementById('strength-text');

        newPwdInput.addEventListener('input', function () {
            const val = this.value;
            let score = 0;
            if (val.length >= 6)  score++;
            if (val.length >= 10) score++;
            if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;

            strengthBar.className = 'password-strength-bar-fill';
            if (val.length === 0) { strengthText.textContent = ''; return; }

            if (score === 0) {
                strengthBar.classList.add('strength-very-weak');
                strengthText.textContent = 'Rất yếu';
                strengthText.style.color = '#ff4d4f';
            } else if (score === 1) {
                strengthBar.classList.add('strength-weak');
                strengthText.textContent = 'Yếu';
                strengthText.style.color = '#ffa940';
            } else if (score === 2) {
                strengthBar.classList.add('strength-medium');
                strengthText.textContent = 'Trung bình';
                strengthText.style.color = '#b7ce63ff';
            } else {
                strengthBar.classList.add('strength-strong');
                strengthText.textContent = 'Mạnh';
                strengthText.style.color = '#0c9316ff';
            }

            checkMatch();
        });

        // Confirm match hint
        const confirmInput = document.getElementById('confirmPassword');
        const matchHint = document.getElementById('match-hint');

        confirmInput.addEventListener('input', checkMatch);

        function checkMatch() {
            if (!confirmInput.value) { matchHint.textContent = ''; return; }
            if (newPwdInput.value === confirmInput.value) {
                matchHint.textContent = '✓ Mật khẩu khớp';
                matchHint.style.color = '#52c41a';
            } else {
                matchHint.textContent = '✗ Mật khẩu chưa khớp';
                matchHint.style.color = '#ff4d4f';
            }
        }

        // Client-side validation before submit
        document.getElementById('resetForm').addEventListener('submit', function (e) {
            const pwd = newPwdInput.value;
            const confirm = confirmInput.value;
            if (pwd.length < 6) {
                e.preventDefault();
                alert('Mật khẩu phải có ít nhất 6 ký tự!');
                return;
            }
            if (pwd !== confirm) {
                e.preventDefault();
                alert('Mật khẩu xác nhận không khớp!');
            }
        });
    </script>
</body>
</html>
