@using Microsoft.AspNetCore.Http;

@{
    // Auth guard
    if (Context.Session.GetInt32("userid") == null)
    {
        Context.Response.Redirect("/Home/Login");
        return;
    }

    string fullName      = Context.Session.GetString("fullname") ?? "Người dùng";
    string pageTitle     = ViewBag.PageTitle as string ?? "RTC";
    string activeSidebar = ViewBag.ActiveSidebar as string ?? "home";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <meta name="description" content="Nền tảng học tập trực tuyến RTC" />
    <link rel="icon" type="image/x-icon" href="~/assets/img/favicon/icon-logo-RTC-2023.ico" />
    <link href="~/assets/css/fontcss2.css" rel="stylesheet" />
      <link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet" />

    <!-- Icons. Uncomment required icon fonts -->
    <link rel="stylesheet" href="~/assets/vendor/fonts/boxicons.css" />

    <!-- Core CSS -->
    <link rel="stylesheet" href="~/assets/vendor/css/core.css" class="template-customizer-core-css" />
    <link rel="stylesheet" href="~/assets/vendor/css/theme-default.css" class="template-customizer-theme-css" />
    <link rel="stylesheet" href="~/assets/css/demo.css" />

    <!-- Vendors CSS -->
    <link rel="stylesheet" href="~/assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.css" />

    <link rel="stylesheet" href="~/assets/vendor/libs/apex-charts/apex-charts.css" />

    <!-- Page CSS -->
    <!-- Helpers -->
    <script src="~/assets/vendor/js/helpers.js"></script>

    <!--! Template customizer & Theme config files MUST be included after core stylesheets and helpers.js in the <head> section -->
    <!--? Config:  Mandatory theme config file contain global vars & default theme options, Set your preferred theme option in this file.  -->
    <script src="~/assets/js/config.js"></script>

    <script src="~/lib/Jquery-3.6.0.min.js"></script>
    @*<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>*@
    <script src="~/assets/js/sweetalert2@11.js"></script>

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: #f5f5f5;
            color: #333;
        }

        /* ===== TOPBAR ===== */
        .topbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 60px;
            background: #fff;
            border-bottom: 1px solid #e8e8e8;
            display: flex;
            align-items: center;
            padding: 0 16px;
            gap: 16px;
            z-index: 1000;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
        }

        .topbar-logo {
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            flex-shrink: 0;
        }

            .topbar-logo img {
                height: 36px;
            }

        .topbar-search {
            flex: 1;
            max-width: 480px;
            margin: 0 auto;
            position: relative;
        }

            .topbar-search input {
                width: 100%;
                height: 38px;
                border: 1px solid #d9d9d9;
                border-radius: 20px;
                padding: 0 16px 0 40px;
                font-size: 14px;
                outline: none;
                background: #f5f5f5;
                transition: border-color .2s, background .2s;
            }

                .topbar-search input:focus {
                    border-color: #1677ff;
                    background: #fff;
                }

            .topbar-search .search-icon {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #999;
                font-size: 16px;
            }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-shrink: 0;
        }

        .topbar-user {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            font-weight: 600;
            color: #333;
        }

        .topbar-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, #1677ff, #764ba2);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 14px;
            font-weight: 700;
        }

        .topbar-logout {
            font-size: 13px;
            color: #999;
            text-decoration: none;
            padding: 6px 12px;
            border: 1px solid #e8e8e8;
            border-radius: 6px;
            transition: all .2s;
        }

            .topbar-logout:hover {
                border-color: #ff4d4f;
                color: #ff4d4f;
            }

        /* ===== SIDEBAR ===== */
        .sidebar {
            position: fixed;
            top: 60px;
            left: 0;
            bottom: 0;
            width: 72px;
            background: #fff;
            border-right: 1px solid #e8e8e8;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 16px 0;
            gap: 4px;
            z-index: 900;
            overflow-y: auto;
        }

        .sidebar-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            width: 64px;
            padding: 10px 4px;
            border-radius: 10px;
            cursor: pointer;
            text-decoration: none;
            color: #555;
            font-size: 11px;
            font-weight: 500;
            transition: background .2s, color .2s;
            text-align: center;
        }

            .sidebar-item:hover, .sidebar-item.active {
                background: #e8f4ff;
                color: #1677ff;
            }

            .sidebar-item i {
                font-size: 22px;
            }

        /* ===== MAIN CONTENT ===== */
        .main-content {
            margin: 70px 10px 30px 85px;
            min-height: calc(100vh - 60px);
        }


        /* ===== BANNER ===== */
        .banner {
            background: linear-gradient(135deg, #00c6fb 0%, #005bea 100%);
            border-radius: 16px;
            padding: 36px 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 32px;
            overflow: hidden;
            position: relative;
            min-height: 180px;
        }
        .banner-content { flex: 1; z-index: 1; }
        .banner-content .banner-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(255,255,255,.2);
            color: #fff;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 12px;
        }
        .banner-content h2 {
            font-size: 28px;
            font-weight: 800;
            color: #fff;
            margin-bottom: 10px;
            line-height: 1.3;
        }
        .banner-content p {
            font-size: 14px;
            color: rgba(255,255,255,.85);
            margin-bottom: 20px;
            max-width: 480px;
            line-height: 1.6;
        }
        .banner-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #fff;
            color: #005bea;
            font-weight: 700;
            font-size: 14px;
            padding: 10px 22px;
            border-radius: 25px;
            text-decoration: none;
            transition: transform .2s, box-shadow .2s;
        }
        .banner-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,.15); color: #005bea; }
        .banner-image { flex-shrink: 0; width: 220px; text-align: right; z-index: 1; }
        .banner-illustration {
            width: 200px; height: 130px;
            background: rgba(255,255,255,.15);
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            backdrop-filter: blur(6px);
        }
        .banner-illustration i { font-size: 64px; color: rgba(255,255,255,.7); }
        .banner-blob {
            position: absolute;
            width: 300px; height: 300px;
            background: rgba(255,255,255,.06);
            border-radius: 50%;
            right: -80px; top: -80px;
        }

        /* ===== SECTION HEADER ===== */
        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }
        .section-title { font-size: 20px; font-weight: 700; color: #1a1a1a; }
        .section-title span { color: #1677ff; }

        /* ===== COURSE GRID ===== */
        .course-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 20px;
            margin-bottom: 32px;
        }
        @@media (max-width: 1280px) { .course-grid { grid-template-columns: repeat(4, 1fr); } }
        @@media (max-width: 992px)  { .course-grid { grid-template-columns: repeat(3, 1fr); } }
        @@media (max-width: 640px)  { .course-grid { grid-template-columns: repeat(2, 1fr); } }
        @@media (max-width: 400px)  { .course-grid { grid-template-columns: 1fr; } }

        /* ===== COURSE CARD ===== */
        .course-card {
            background: #fff;
            border-radius: 10px;
            overflow: hidden;
            cursor: pointer;
            transition: transform .2s, box-shadow .2s;
            text-decoration: none;
            color: inherit;
            display: block;
            border: 1px solid #efefef;
        }
        .course-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 32px rgba(0,0,0,.1);
            color: inherit;
            text-decoration: none;
        }
        .course-card.locked { cursor: not-allowed; opacity: .75; }
        .course-card.locked:hover { transform: none; box-shadow: none; }

        .course-thumbnail {
            width: 100%;
            aspect-ratio: 16/9;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }
        .course-thumbnail i { font-size: 48px; color: rgba(255,255,255,.6); }
        .course-thumbnail .thumb-tag {
            position: absolute;
            top: 8px; right: 8px;
            background: rgba(0,0,0,.45);
            color: #fff;
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 4px;
        }

        .thumb-0 { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .thumb-1 { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
        .thumb-2 { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
        .thumb-3 { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
        .thumb-4 { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
        .thumb-5 { background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%); }
        .thumb-6 { background: linear-gradient(135deg, #fccb90 0%, #d57eeb 100%); }
        .thumb-7 { background: linear-gradient(135deg, #30cfd0 0%, #330867 100%); }

        .course-info { padding: 12px 14px; }
        .course-name {
            font-size: 14px; font-weight: 700; color: #1a1a1a;
            line-height: 1.4; margin-bottom: 4px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .course-instructor {
            font-size: 12px; color: #777; margin-bottom: 8px;
            display: flex; align-items: center; gap: 4px;
        }
        .course-rating { display: flex; align-items: center; gap: 4px; margin-bottom: 6px; }
        .stars { color: #f5a623; font-size: 12px; }
        .rating-val { font-size: 12px; font-weight: 700; color: #f5a623; }
        .rating-count { font-size: 11px; color: #999; }
        .course-price { font-size: 14px; font-weight: 700; color: #1677ff; margin-bottom: 8px; }
        .course-price.free { color: #52c41a; }
        .course-meta {
            display: flex; align-items: center; gap: 12px;
            font-size: 11px; color: #999;
            border-top: 1px solid #f0f0f0;
            padding-top: 8px; margin-top: 4px;
        }
        .course-meta span { display: flex; align-items: center; gap: 3px; }

        .course-progress { margin-top: 8px; }
        .progress-bar-wrap { height: 4px; background: #e8e8e8; border-radius: 4px; overflow: hidden; }
        .progress-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, #1677ff, #52c3ff);
            border-radius: 4px;
            transition: width .4s;
        }
        .progress-label {
            display: flex; justify-content: space-between;
            font-size: 11px; color: #999; margin-top: 3px;
        }

        .lock-overlay {
            position: absolute; inset: 0;
            background: rgba(0,0,0,.35);
            display: flex; align-items: center; justify-content: center;
        }
        .lock-overlay i { font-size: 28px; color: #fff; }

        .empty-state { text-align: center; padding: 64px 24px; color: #999; }
        .empty-state i { font-size: 64px; color: #d9d9d9; margin-bottom: 16px; }
        .empty-state p { font-size: 16px; }

        .stats-bar {
            display: flex; gap: 24px;
            background: #fff; border-radius: 12px;
            padding: 16px 24px; margin-bottom: 24px;
            border: 1px solid #efefef;
        }
        .stat-item { text-align: center; }
        .stat-value { font-size: 22px; font-weight: 800; color: #1677ff; }
        .stat-label { font-size: 12px; color: #999; margin-top: 2px; }

        /* ===== NOTIFICATIONS ===== */
        .topbar-notification {
            position: relative;
            margin-right: 8px;
        }
        .topbar-notification-btn {
            background: none;
            border: none;
            cursor: pointer;
            padding: 8px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }
        .topbar-notification-btn:hover {
            background: #f3f4f6;
        }
        .topbar-notification-btn i {
            font-size: 22px;
            color: #4b5563;
        }
        .notification-badge {
            font-size: 10px;
            padding: 3px 6px;
            border: 2px solid #fff;
            transform: translate(30%, -30%);
        }
        #notification-dropdown-menu {
            width: 340px;
            max-height: 480px;
            overflow-y: auto;
            border-radius: 12px;
            margin-top: 10px !important;
            border: 1px solid #e5e7eb;
            padding: 0;
        }
        .notification-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 16px;
            border-bottom: 1px solid #f3f4f6;
        }
        .notification-header h6 {
            margin: 0;
            font-weight: 700;
            color: #111827;
            font-size: 15px;
        }
        .notification-header .btn-mark-all {
            font-size: 12px;
            color: #1677ff;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0;
            font-weight: 500;
            outline: none;
        }
        .notification-header .btn-mark-all:hover {
            text-decoration: underline;
        }
        .notification-item-list {
            padding: 0;
            margin: 0;
            list-style: none;
        }
        .notification-item {
            display: flex;
            gap: 12px;
            padding: 12px 16px;
            border-bottom: 1px solid #f9fafb;
            cursor: pointer;
            transition: background 0.2s;
            text-decoration: none !important;
            color: inherit !important;
        }
        .notification-item:hover {
            background: #f9fafb;
        }
        .notification-item.unread {
            background: #eff6ff;
        }
        .notification-item.unread:hover {
            background: #dbeafe;
        }
        .notification-item-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, #1677ff, #764ba2);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 14px;
            flex-shrink: 0;
            overflow: hidden;
        }
        .notification-item-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .notification-item-content {
            flex: 1;
            font-size: 13px;
            line-height: 1.4;
            color: #374151;
        }
        .notification-item-content p {
            margin: 0 0 4px 0;
        }
        .notification-item-time {
            font-size: 11px;
            color: #9ca3af;
        }
        .notification-unread-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background-color: #1677ff;
            align-self: center;
            flex-shrink: 0;
        }
        .notification-item-content b {
            color: #1677ff;
            font-weight: 700;
        }

        /* ===== MY COURSES DROPDOWN ===== */
        .topbar-mycourses {
            position: relative;
            margin-right: 4px;
        }
        #mycourses-dropdown-menu {
            width: 400px;
            max-height: 480px;
            overflow-y: auto;
            border-radius: 12px;
            margin-top: 10px !important;
            border: 1px solid #e5e7eb;
            padding: 0;
        }
        .mycourse-item {
            display: flex;
            gap: 12px;
            padding: 12px 16px;
            border-bottom: 1px solid #f9fafb;
            cursor: pointer;
            transition: background 0.2s;
            text-decoration: none !important;
            color: inherit !important;
        }
        .mycourse-item:hover {
            background: #f3f4f6;
        }
        .mycourse-item-thumb {
            width: 60px;
            height: 45px;
            border-radius: 6px;
            background: #f3f4f6;
            flex-shrink: 0;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .mycourse-item-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .mycourse-item-thumb i {
            font-size: 24px;
            color: #9ca3af;
        }
        .mycourse-item-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            min-width: 0;
        }
        .mycourse-item-name {
            font-size: 13px;
            font-weight: 600;
            color: #111827;
            margin: 0 0 6px 0;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            line-height: 1.4;
        }
        .mycourse-item-progress {
            margin-top: auto;
        }
        .mycourse-item-progress .course-progress {
            margin-top: 0;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <header class="topbar">
        <a asp-controller="Home" asp-action="Index" class="topbar-logo">
            <img src="~/assets/img/logo-RTC-2023-1200-banchuan.png" alt="RTCCourse" />
        </a>

        <div class="topbar-search">
            <i class="bx bx-search search-icon"></i>
            <input type="text" id="search-input" placeholder="Tìm khoá học..." autocomplete="off" />
        </div>

        <div class="topbar-right">
            <!-- My Courses Dropdown -->
            <div class="topbar-mycourses dropdown">
                <button class="topbar-notification-btn position-relative" data-bs-toggle="dropdown" aria-expanded="false" id="myCoursesBtn" onclick="loadMyCourses()" title="Khóa học đã học">
                    <i class="bx bx-book-reader"></i>
                </button>
                <div class="dropdown-menu dropdown-menu-end shadow" id="mycourses-dropdown-menu" aria-labelledby="myCoursesBtn">
                    <div class="notification-header">
                        <h6>Khóa học đã học</h6>
                    </div>
                    <ul class="notification-item-list" id="mycourses-list-container">
                        <li class="p-3 text-center text-muted">Đang tải...</li>
                    </ul>
                    <div class="p-2 border-top text-center" id="mycourses-viewall-container" style="display: none;">
                        <button type="button" class="btn btn-sm btn-link text-decoration-none" style="font-weight: 500; font-size: 13px;" onclick="loadMyCourses(event, true)">Xem thêm</button>
                    </div>
                </div>
            </div>

            <!-- Notification Bell Dropdown -->
            <div class="topbar-notification dropdown">
                <button class="topbar-notification-btn position-relative" data-bs-toggle="dropdown" aria-expanded="false" id="notificationBellBtn" onclick="loadNotifications()" title="Thông báo">
                    <i class="bx bx-bell"></i>
                    <span class="notification-badge position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="notification-unread-count" style="display: none;">0</span>
                </button>
                <div class="dropdown-menu dropdown-menu-end shadow" id="notification-dropdown-menu" aria-labelledby="notificationBellBtn">
                    <div class="notification-header">
                        <h6>Thông báo</h6>
                        <button class="btn-mark-all" onclick="markAllNotificationsAsRead(event)">Đánh dấu tất cả là đã đọc</button>
                    </div>
                    <ul class="notification-item-list" id="notification-list-container">
                        <li class="p-3 text-center text-muted">Đang tải...</li>
                    </ul>
                </div>
            </div>

            <div class="topbar-user">
                <div class="topbar-avatar">@(fullName.Length > 0 ? fullName[0].ToString().ToUpper() : "U")</div>
                <span>@fullName</span>
            </div>
            <a asp-controller="Home" asp-action="Logout" class="topbar-logout">
                <i class="bx bx-log-out"></i> Đăng xuất
            </a>
        </div>
    </header>

    <aside class="sidebar">
        <a asp-controller="Home" asp-action="Index" class="sidebar-item @(activeSidebar == "home" ? "active" : "")">
            <i class="bx bx-home-alt"></i>
            <span>Trang chủ</span>
        </a>
        <!-- <a href="#" class="sidebar-item" @(activeSidebar == "roadmap" ? "active" : "")">
            <i class="bx bx-map-alt"></i>
            <span>Lộ trình</span>
        </a>
        <a href="#" class="sidebar-item" @(activeSidebar == "posts" ? "active" : "")">
            <i class="bx bx-news"></i>
            <span>Bài viết</span>
        </a> -->
    </aside>
    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">
        @RenderBody()
    </main>

    <script src="~/lib/Jquery-3.6.0.min.js"></script>
    <script src="~/assets/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/sweetalert2@11.js"></script>
    <script src="~/js/common.js" asp-append-version="true"></script>
    <script src="~/assets/js/dashboards-analytics.js"></script>
    <script src="~/js/menu.js" asp-append-version="true"></script>
    <script src="~/assets/js/moment.min.js"></script>

    @await Component.InvokeAsync("Notyf")
    @await RenderSectionAsync("Scripts", required: false)

    <!-- SignalR CDN & Global Notifications Script -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        var globalEmployeeId = @(Context.Session.GetInt32("employeeid") ?? 0);
        var globalHubConnection = null;

        $(document).ready(function() {
            if (globalEmployeeId > 0) {
                // Tải trước số thông báo chưa đọc
                fetchUnreadCount();

                // Khởi tạo kết nối SignalR toàn cục
                initGlobalSignalR();
            }
        });

        function fetchUnreadCount() {
            $.get("/Lesson/GetNotifications", function(res) {
                if (res.success) {
                    updateUnreadBadge(res.unreadCount);
                }
            });
        }

        function updateUnreadBadge(count) {
            var $badge = $("#notification-unread-count");
            if (count > 0) {
                $badge.text(count).show();
            } else {
                $badge.hide().text("0");
            }
        }

        function initGlobalSignalR() {
            if (typeof signalR === "undefined") return;

            globalHubConnection = new signalR.HubConnectionBuilder()
                .withUrl("/commentHub")
                .withAutomaticReconnect()
                .build();

            globalHubConnection.on("ReceiveNotification", function(data) {
                // Tăng số lượng badge
                updateUnreadBadge(data.unreadCount);

                // Hiển thị Toast thông báo SweetAlert2
                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 4000,
                    timerProgressBar: true,
                    didOpen: (toast) => {
                        toast.addEventListener('mouseenter', Swal.stopTimer);
                        toast.addEventListener('mouseleave', Swal.resumeTimer);
                        toast.style.cursor = 'pointer';
                        toast.addEventListener('click', function() {
                            clickNotification(data.id, data.targetUrl);
                        });
                    }
                });
                Toast.fire({
                    icon: 'info',
                    html: data.content
                });
            });

            globalHubConnection.start().then(function() {
                globalHubConnection.invoke("JoinUserGroup", globalEmployeeId)
                    .catch(function(err) {
                        console.error("JoinUserGroup error:", err.toString());
                    });
            }).catch(function(err) {
                console.error("SignalR start error:", err.toString());
            });
        }

        function loadNotifications() {
            var $container = $("#notification-list-container");
            $container.html('<li class="p-3 text-center text-muted"><div class="spinner-border spinner-border-sm text-primary" role="status"></div> Đang tải...</li>');

            $.get("/Lesson/GetNotifications", function(res) {
                if (res.success) {
                    updateUnreadBadge(res.unreadCount);
                    $container.empty();

                    if (res.list && res.list.length > 0) {
                        res.list.forEach(function(item) {
                            var isUnreadClass = item.isRead ? "" : "unread";
                            var unreadDot = item.isRead ? "" : '<div class="notification-unread-dot"></div>';
                            
                            // Xử lý avatar
                            var avatarHtml = '';
                            if (item.triggerAvatar) {
                                avatarHtml = '<img src="' + item.triggerAvatar + '" alt="Avatar" />';
                            } else {
                                var letter = item.triggerFullName ? item.triggerFullName.charAt(0).toUpperCase() : 'U';
                                avatarHtml = '<span>' + letter + '</span>';
                            }

                            var li = '<li class="notification-item ' + isUnreadClass + '" onclick="clickNotification(' + item.id + ', \'' + item.targetUrl + '\')">' +
                                     '  <div class="notification-item-avatar">' + avatarHtml + '</div>' +
                                     '  <div class="notification-item-content">' +
                                     '    <p>' + item.content + '</p>' +
                                     '    <div class="notification-item-time">' + item.createdDateFormatted + '</div>' +
                                     '  </div>' +
                                     unreadDot +
                                     '</li>';
                            $container.append(li);
                        });
                    } else {
                        $container.html('<li class="p-3 text-center text-muted">Không có thông báo mới</li>');
                    }
                } else {
                    $container.html('<li class="p-3 text-center text-danger">Lỗi tải thông báo</li>');
                }
            });
        }

        function clickNotification(id, targetUrl) {
            $.post("/Lesson/MarkSingleNotificationAsRead?id=" + id, function() {
                window.location.href = targetUrl;
            }).fail(function() {
                window.location.href = targetUrl;
            });
        }

        function markAllNotificationsAsRead(event) {
            if (event) {
                event.preventDefault();
                event.stopPropagation();
            }

            $.post("/Lesson/MarkNotificationsAsRead", function(res) {
                if (res.success) {
                    // Cập nhật giao diện local
                    $("#notification-unread-count").hide().text("0");
                    $("#notification-list-container .notification-item").removeClass("unread");
                    $("#notification-list-container .notification-unread-dot").remove();
                }
            });
        }

        function escapeHtml(text) {
            if (!text) return "";
            return text
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        var myCoursesSkip = 0;
        var myCoursesTake = 5;
        var isLoadingMoreMyCourses = false;

        function loadMyCourses(event, isLoadMore) {
            if (event) {
                event.stopPropagation();
                event.preventDefault();
            }
            isLoadMore = isLoadMore || false;

            var $container = $("#mycourses-list-container");
            var $viewAll = $("#mycourses-viewall-container");
            var $btnViewAll = $viewAll.find('button');

            if (!isLoadMore) {
                myCoursesSkip = 0;
                myCoursesTake = 5;
                $container.html('<li class="p-3 text-center text-muted"><div class="spinner-border spinner-border-sm text-primary" role="status"></div> Đang tải...</li>');
                $viewAll.hide();
            } else {
                if (isLoadingMoreMyCourses) return;
                isLoadingMoreMyCourses = true;
                myCoursesTake = 999; // Tải tất cả phần còn lại
                $btnViewAll.html('<div class="spinner-border spinner-border-sm text-primary" role="status"></div> Đang tải...');
            }

            $.get("/Course/GetMyCourses?skip=" + myCoursesSkip + "&take=" + myCoursesTake, function(res) {
                if (res.success) {
                    if (!isLoadMore) {
                        $container.empty();
                    }

                    if (res.data && res.data.length > 0) {
                        res.data.forEach(function(item) {
                            var thumbUrl = item.thumbnailUrl || item.ThumbnailUrl;
                            var nameCourse = item.nameCourse || item.NameCourse;
                            var id = item.id || item.ID;
                            var progressPct = item.progressPct !== undefined ? item.progressPct : item.ProgressPct;

                            var defaultThumbnail = "/api/share/Software/Test/UPLOADFILE/CourseLesson/Outsite/Image/thumbnail-default.png";
                            var thumbHtml = thumbUrl 
                                ? '<img src="' + escapeHtml(thumbUrl) + '" alt="Thumbnail" />' 
                                : '<img src="' + defaultThumbnail + '" alt="Thumbnail" />';

                            var progressHtml = '<div class="mycourse-item-progress">' +
                                               '    <div class="course-progress">' +
                                               '        <div class="progress-bar-wrap">' +
                                               '            <div class="progress-bar-fill" style="width:' + progressPct + '%"></div>' +
                                               '        </div>' +
                                               '        <div class="progress-label">' +
                                               '            <span>' + progressPct + '%</span>' +
                                               '        </div>' +
                                               '    </div>' +
                                               '</div>';

                            var li = '<a href="/Lesson/Index?courseId=' + id + '" class="mycourse-item" title="' + escapeHtml(nameCourse) + '">' +
                                     '  <div class="mycourse-item-thumb">' + thumbHtml + '</div>' +
                                     '  <div class="mycourse-item-content">' +
                                     '    <div class="mycourse-item-name">' + escapeHtml(nameCourse) + '</div>' +
                                          progressHtml +
                                     '  </div>' +
                                     '</a>';
                            $container.append(li);
                        });

                        myCoursesSkip += res.data.length;

                        if (res.data.length < myCoursesTake) {
                            $viewAll.hide();
                        } else {
                            $viewAll.show();
                            $btnViewAll.html('Xem thêm');
                        }
                    } else {
                        if (!isLoadMore) {
                            $container.html('<li class="p-3 text-center text-muted">Chưa có khóa học nào</li>');
                        } else {
                            $viewAll.hide();
                        }
                    }
                } else {
                    if (!isLoadMore) {
                        $container.html('<li class="p-3 text-center text-danger">Lỗi tải dữ liệu</li>');
                    }
                }
                isLoadingMoreMyCourses = false;
            }).fail(function() {
                if (!isLoadMore) {
                    $container.html('<li class="p-3 text-center text-danger">Lỗi kết nối máy chủ</li>');
                } else {
                    $btnViewAll.html('Xem thêm');
                }
                isLoadingMoreMyCourses = false;
            });
        }
    </script>

    @* SweetAlert2 Error Modal - Hiển thị lỗi không reload trang *@
    @{
        var errorMsg = Context.Session.GetString("ErrorMessage");
        Context.Session.Remove("ErrorMessage");
    }
    @if (errorMsg != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Thông báo',
                    text: '@Html.Raw(errorMsg)',
                    confirmButtonText: 'Đóng',
                    confirmButtonColor: '#667eea',
                    allowOutsideClick: true,
                    allowEscapeKey: true,
                    heightAuto: false
                });
            });
        </script>
    }
</body>
</html>
